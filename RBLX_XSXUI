-- Настройки
local cubeSize = 4
local permPlatformSize = 4
local tempPlatformSize = 4
local anchored = true
local transparency = 0

-- Функция создания
local function createCube(type, color, name, temporary)
    local player = game.Players.LocalPlayer
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = character.HumanoidRootPart

    local sizeVector = Vector3.new(cubeSize, cubeSize, cubeSize)
    if name == "BLUDX_Platform_PERM" then
        sizeVector = Vector3.new(permPlatformSize, 1, permPlatformSize)
    elseif name == "BLUDX_Platform_TEMP" then
        sizeVector = Vector3.new(tempPlatformSize, 1, tempPlatformSize)
    end

    local part = Instance.new("Part")
    part.Size = sizeVector
    part.Anchored = anchored
    part.Transparency = transparency
    part.Position = hrp.Position - Vector3.new(0, hrp.Size.Y / 2 + sizeVector.Y / 2, 0)
    part.Color = color
    part.Material = Enum.Material.SmoothPlastic
    part.Name = name
    part.Parent = workspace

    if temporary then
        task.delay(3, function()
            if part and part.Parent then
                part:Destroy()
            end
        end)
    end
end

-- Переменная режима
local placingEnabled = false
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()

-- Raycast и создание куба по клику
local function placeCubeAtMouse()
    local unitRay = workspace.CurrentCamera:ScreenPointToRay(mouse.X, mouse.Y)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {player.Character}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist

    local rayResult = workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, raycastParams)
    if rayResult then
        local part = Instance.new("Part")
        part.Size = Vector3.new(cubeSize, cubeSize, cubeSize)
        part.Anchored = anchored
        part.Transparency = transparency
        part.Position = rayResult.Position + Vector3.new(0, cubeSize / 2, 0)
        part.Color = Color3.fromRGB(255, 200, 100)
        part.Material = Enum.Material.SmoothPlastic
        part.Name = "BLUDX_ClickCube"
        part.Parent = workspace
    end
end

-- Подключение к клику
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and placingEnabled and input.UserInputType == Enum.UserInputType.MouseButton1 then
        placeCubeAtMouse()
    end
end)

