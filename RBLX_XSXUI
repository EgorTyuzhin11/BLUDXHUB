-- ClickTp Toggle
local clickTPConnection
local isAltHeld = false

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

local clickTPConnection
local altBeginConnection
local altEndConnection
local isAltHeld = false

local ClickTpToggle = TPTab:NewToggle("Click TP", false, function(enabled)
    if enabled then
        -- Подключаем события на Alt
        altBeginConnection = UIS.InputBegan:Connect(function(input, gameProcessed)
            if input.KeyCode == Enum.KeyCode.LeftAlt then
                isAltHeld = true
            end
        end)

        altEndConnection = UIS.InputEnded:Connect(function(input)
            if input.KeyCode == Enum.KeyCode.LeftAlt then
                isAltHeld = false
            end
        end)

        -- Обработка клика мыши при зажатом Alt
        clickTPConnection = UIS.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 and isAltHeld then
                local character = LocalPlayer.Character
                local root = character and character:FindFirstChild("HumanoidRootPart")
                if root and Mouse then
                    local targetPosition = Mouse.Hit.Position
                    root.CFrame = CFrame.new(targetPosition + Vector3.new(0, 5, 0))
                end
            end
        end)
    else
        -- Отключаем все соединения
        if clickTPConnection then
            clickTPConnection:Disconnect()
            clickTPConnection = nil
        end
        if altBeginConnection then
            altBeginConnection:Disconnect()
            altBeginConnection = nil
        end
        if altEndConnection then
            altEndConnection:Disconnect()
            altEndConnection = nil
        end
        isAltHeld = false
    end
end)

-- Friend Menu

local FriendTab = Init:NewTab("FriendMenu")
local FriendSection = FriendTab:NewSection("Управление друзьями")

local currentFriend = nil
local spectateConnection = nil

local function stopSpectate()
    if spectateConnection then
        spectateConnection:Disconnect()
        spectateConnection = nil
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    end
end

local FriendText = FriendTab:NewTextbox(
    "Добавить друга",
    "Введите ник друга",
    "Ник",
    "all",
    "medium",
    true,
    false,
    function(val)
        local input = val:gsub("%s+", "") -- Удаляем пробелы
        if input == "" then return end

        for _, player in ipairs(Players:GetPlayers()) do
            if player.Name:lower() == input:lower() then
                currentFriend = player.Name
                Notif:Notify("Текущий друг: " .. currentFriend, 4, "success")
                stopSpectate() -- выключаем слежение, если друг меняется
                return
            end
        end

        Notif:Notify("Игрок '" .. input .. "' не найден на сервере.", 4, "error")
    end
)

-- Кнопка телепортации
local teleportBtn = FriendTab:NewButton("Teleport to friend", function()
    if not currentFriend then
        Notif:Notify("Сначала выберите друга.", 4, "alert")
        return
    end

    local localChar = Players.LocalPlayer.Character
    local targetPlayer = Players:FindFirstChild(currentFriend)
    local targetChar = targetPlayer and targetPlayer.Character

    if localChar and targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
        localChar:MoveTo(targetChar.HumanoidRootPart.Position + Vector3.new(0, 3, 0))
    else
        Notif:Notify("Невозможно телепортироваться к " .. currentFriend, 4, "error")
    end
end)

-- Кнопка spectate
local spectateBtn = FriendTab:NewButton("Spectate friend", function()
    if not currentFriend then
        Notif:Notify("Сначала выберите друга.", 4, "alert")
        return
    end

    local targetPlayer = Players:FindFirstChild(currentFriend)
    local cam = workspace.CurrentCamera

    if not spectateConnection then
        if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            Notif:Notify("Невозможно следить за " .. currentFriend, 4, "error")
            return
        end

        Notif:Notify("Начато наблюдение за " .. currentFriend, 4, "information")
        cam.CameraType = Enum.CameraType.Scriptable
        spectateConnection = game:GetService("RunService").RenderStepped:Connect(function()
            if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                cam.CFrame = targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 5, 10)
            else
                Notif:Notify(currentFriend .. " вышел или исчез.", 4, "error")
                stopSpectate()
            end
        end)

        Players.PlayerRemoving:Connect(function(player)
            if currentFriend and player.Name == currentFriend then
                Notif:Notify(currentFriend .. " покинул игру. Слежение остановлено.", 4, "error")
                stopSpectate()
                currentFriend = nil
            end
        end)

        
    else
        Notif:Notify("Наблюдение остановлено", 4, "information")
        stopSpectate()
    end
end)

local deleteBtn = FriendTab:NewButton("Delete friend", function()
    if currentFriend then
        Notif:Notify("Удален друг: " .. currentFriend, 4, "notification")
        stopSpectate()
        currentFriend = nil
    else
        Notif:Notify("Нет активного друга", 4, "alert")
    end
end)

