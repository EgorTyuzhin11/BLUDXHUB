-- ESP Tab
local ESPTab = Init:NewTab("ESP")
local ESPSection = ESPTab:NewSection("Настройки ESP")

local ESP = {
    Box = false,
    Name = false,
    Tracer = false,
    Health = false,
    Distance = false,
}

-- Отдельная секция для "Только для друга"

local FriendOnly = {
    Box = false,
    Name = false,
    Tracer = false,
    Health = false,
    Distance = false,
}

local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local espObjects = {}

local friendColor = Color3.fromRGB(0, 255, 0)
local defaultColor = Color3.fromRGB(255, 0, 0)

local function createESPForPlayer(plr)
    if plr == LocalPlayer then return end

    local box = Drawing.new("Square")
    box.Visible = false
    box.Color = defaultColor
    box.Thickness = 2
    box.Filled = false

    local nameText = Drawing.new("Text")
    nameText.Visible = false
    nameText.Color = Color3.new(1,1,1)
    nameText.Center = true
    nameText.Outline = true
    nameText.OutlineColor = Color3.new(0,0,0)
    nameText.Size = 16
    nameText.Font = 2

    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = defaultColor
    tracer.Thickness = 1

    local healthText = Drawing.new("Text")
    healthText.Visible = false
    healthText.Color = Color3.new(1,0,0)
    healthText.Center = true
    healthText.Outline = true
    healthText.OutlineColor = Color3.new(0,0,0)
    healthText.Size = 16
    healthText.Font = 2

    local distanceText = Drawing.new("Text")
    distanceText.Visible = false
    distanceText.Color = Color3.new(1,1,1)
    distanceText.Center = true
    distanceText.Outline = true
    distanceText.OutlineColor = Color3.new(0,0,0)
    distanceText.Size = 16
    distanceText.Font = 2

    espObjects[plr] = {
        Box = box,
        Name = nameText,
        Tracer = tracer,
        Health = healthText,
        Distance = distanceText,
    }
end

local function removeESPForPlayer(plr)
    local esp = espObjects[plr]
    if esp then
        for _, obj in pairs(esp) do
            obj:Remove()
        end
        espObjects[plr] = nil
    end
end

for _, plr in pairs(Players:GetPlayers()) do
    createESPForPlayer(plr)
end

Players.PlayerAdded:Connect(function(plr)
    createESPForPlayer(plr)
end)

Players.PlayerRemoving:Connect(function(plr)
    removeESPForPlayer(plr)
end)

RunService.RenderStepped:Connect(function()
    for plr, esp in pairs(espObjects) do
        local char = plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        if hrp and humanoid and humanoid.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local head = char:FindFirstChild("Head")
                local headPos, headOnScreen = head and Camera:WorldToViewportPoint(head.Position) or pos, true

                local height = (pos.Y - headPos.Y)
                local width = height / 2

                local isFriend = (currentFriend == plr.Name)
                local color = isFriend and friendColor or defaultColor

                -- Box
                esp.Box.Visible = ESP.Box and (not FriendOnly.Box or isFriend)
                esp.Box.Color = color
                esp.Box.Position = Vector2.new(headPos.X - width/2, headPos.Y)
                esp.Box.Size = Vector2.new(width, height)

                -- Name
                esp.Name.Visible = ESP.Name and (not FriendOnly.Name or isFriend)
                esp.Name.Text = plr.Name
                esp.Name.Position = Vector2.new(headPos.X, headPos.Y - 15)

                -- Tracer
                esp.Tracer.Visible = ESP.Tracer and (not FriendOnly.Tracer or isFriend)
                esp.Tracer.Color = color
                esp.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                esp.Tracer.To = Vector2.new(pos.X, pos.Y)

                -- Health
                esp.Health.Visible = ESP.Health and (not FriendOnly.Health or isFriend)
                esp.Health.Text = math.floor(humanoid.Health) .. " HP"
                esp.Health.Position = Vector2.new(headPos.X, headPos.Y + height + 5)

                -- Distance
                esp.Distance.Visible = ESP.Distance and (not FriendOnly.Distance or isFriend)
                local dist = (hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                esp.Distance.Text = tostring(math.floor(dist)) .. " метров"
                esp.Distance.Position = Vector2.new(headPos.X, headPos.Y + height + 20)
            else
                esp.Box.Visible = false
                esp.Name.Visible = false
                esp.Tracer.Visible = false
                esp.Health.Visible = false
                esp.Distance.Visible = false
            end
        else
            esp.Box.Visible = false
            esp.Name.Visible = false
            esp.Tracer.Visible = false
            esp.Health.Visible = false
            esp.Distance.Visible = false
        end
    end
end)
